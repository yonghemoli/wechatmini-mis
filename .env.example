GITHUB_TOKEN=
# 服务器直连 GitHub 不稳定时再开启
GITHUB_REWRITE_BASE=ghfast.top/https://github.com
# ========== 家政 MIS 系统配置 ==========
# 复制为 .env 并根据实际情况修改

# 应用基本配置
MIS_NAME=yonghemolimis
MIS_MODE=release                   # debug / release

# 服务器配置
MIS_SERVER_HOST=127.0.0.1
MIS_SERVER_PORT=8080

# Session 配置
MIS_SESSION_EXPIRES_DAYS=30

# 日志配置
MIS_LOG_LEVEL=info                 # debug / info / warn / error
MIS_LOG_FILENAME=work/logs

# ===== 业务数据库 (MySQL, 读写) =====
MIS_DB_DRIVER=mysql
MIS_DB_DSN='root:password@tcp(127.0.0.1:3306)/yonghemolimis?charset=utf8mb4&parseTime=True&loc=Local'
MIS_DB_AUTO_MIGRATE=false          # 首次建表或表结构变更时临时设为 true
