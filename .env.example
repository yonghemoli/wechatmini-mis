GITHUB_TOKEN=
# 服务器直连 GitHub 不稳定时再开启
GITHUB_REWRITE_BASE=ghfast.top/https://github.com
# ========== 家政 MIS 系统配置 ==========
# 复制为 .env 并根据实际情况修改

# 应用基本配置
ANALYTICS_NAME=yonghemoli-mis
ANALYTICS_MODE=release                   # debug / release

# 服务器配置
ANALYTICS_SERVER_HOST=127.0.0.1
ANALYTICS_SERVER_PORT=8080

# Session 配置
ANALYTICS_SESSION_EXPIRES_DAYS=30

# 日志配置
ANALYTICS_LOG_LEVEL=info                 # debug / info / warn / error
ANALYTICS_LOG_FILENAME=work/logs

# 内部管理员
MIS_ADMIN_USERNAME=admin
MIS_ADMIN_PASSWORD=admin123
MIS_ADMIN_EMAIL=admin@yonghemoli.local

# ===== 业务数据库 (MySQL, 读写) =====
ANALYTICS_DB_DRIVER=mysql
ANALYTICS_DB_DSN=root:password@tcp(127.0.0.1:3306)/yonghemolimis?charset=utf8mb4&parseTime=True&loc=Local
ANALYTICS_DB_AUTO_MIGRATE=true           # 首次启动设为 true，自动建表
