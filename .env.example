GITHUB_TOKEN=
# 服务器直连 GitHub 不稳定时再开启
GITHUB_REWRITE_BASE=ghfast.top/https://github.com
# ========== 修仙游戏数据分析系统 配置 ==========
# 复制为 .env 并根据实际情况修改

# 应用基本配置
ANALYTICS_NAME=xiuxian-analytics
ANALYTICS_MODE=release                   # debug / release

# 服务器配置
ANALYTICS_SERVER_HOST=127.0.0.1
ANALYTICS_SERVER_PORT=8080

# Session 配置
ANALYTICS_SESSION_EXPIRES_DAYS=30

# 日志配置
ANALYTICS_LOG_LEVEL=info                 # debug / info / warn / error
ANALYTICS_LOG_FILENAME=work/logs

# ===== 游戏数据库 (MySQL, 只读) =====
ANALYTICS_GAME_DB_DRIVER=mysql
# 方式一: 直接提供 DSN (优先级高)
# ANALYTICS_GAME_DB_DSN=root:password@tcp(127.0.0.1:3306)/xiuxian_release?charset=utf8mb4&parseTime=True&loc=Local

# ===== 分析数据库 (PostgreSQL, 读写) =====
ANALYTICS_DB_DRIVER=postgres
ANALYTICS_DB_DSN=host=127.0.0.1 user=analytics password=analytics_pwd dbname=xiuxian_analytics port=5432 sslmode=disable TimeZone=Asia/Shanghai
ANALYTICS_DB_AUTO_MIGRATE=true           # 首次启动设为 true，自动建表
