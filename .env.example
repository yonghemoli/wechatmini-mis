# ========== 永和茉莉 系统配置 ==========
# 复制为 .env 并根据实际情况修改

# 应用基本配置
MIS_NAME=yonghemolimis
MIS_MODE=release                   # debug / release

# 服务器配置
MIS_SERVER_HOST=127.0.0.1
MIS_SERVER_PORT=8080

# Session 配置
MIS_SESSION_EXPIRES_DAYS=30

# 小程序微信登录配置
# 未配置时仅用于开发联调：后端会用 wx.login code 生成 dev openid，不会伪造手机号
MIS_MINI_WECHAT_APPID='wx6edad54066c67719'
MIS_MINI_WECHAT_SECRET='cfe499eff2ab070816cf52b7e030cc60'
# 抖音小程序
MIS_MINI_DOUYIN_APPID=ttf01386ae6e76d72401
MIS_MINI_DOUYIN_SECRET=9e041e45d42fdd7208a882cac155691173805a0d
# 抖音控制台“开发配置 > 应用公钥”对应的私钥。单行环境变量请用 \n 表示换行。
MIS_MINI_DOUYIN_PHONE_PRIVATE_KEY='-----BEGIN PUBLIC KEY-----\nMIIBIjANBgkqhkiG9w0BAQEFAAOCAQ8AMIIBCgKCAQEAwFyQuvp+lzKKqsH1MHcW\n60Fu6Fe21Jac9ZMi2yHM/rKVSoxSep3l20muGQzzskeHboJc8pQO4eqDliHIKcyt\n87O7Kbo+vG5QvQqz0KRA/qURgb1GaV1ycxxiQwv/fY7JNE+rC2dJR2Yuy+J5Qn4n\nPNWgHq9lMfWTJGvKQfLBBpjJ1vosgZEMAW1JRNCNodM7Io7GT9UtbbcafSH3/B4k\nHlICUnvqZYDiAh5bGK9aRNFqJBzKP8pho9QllLI9yQqy3fI0yQfOqUNQ9WbDRcMK\nS5F04HC+3DfMLrNnbWvXV9q9BOtz+6st6pSHYF+JGuD7fdRTTCqNu9QKKXJc3lau\nlwIDAQAB\n-----END PUBLIC KEY-----'

# 小程序短信验证码。生产环境配置 HTTP JSON 网关；仅 debug 环境可配置固定测试码。
MIS_MINI_SMS_ENDPOINT=
MIS_MINI_SMS_TOKEN=
MIS_MINI_SMS_TEST_CODE=

# 日志配置
MIS_LOG_LEVEL=info                 # debug / info / warn / error
MIS_LOG_FILENAME=work/logs

# ===== 业务数据库 (MySQL, 读写) =====
MIS_DB_DRIVER=mysql
MIS_DB_DSN='root:password@tcp(127.0.0.1:3306)/yonghemolimis?charset=utf8mb4&parseTime=True&loc=Local'
MIS_DB_AUTO_MIGRATE=false          # 首次建表或表结构变更时临时设为 true

MIS_OSS_ENDPOINT=oss-files.alemonjs.com
MIS_OSS_ACCESS_KEY=lemonade
MIS_OSS_SECRET_KEY=lemonade
MIS_OSS_USE_SSL=true
MIS_OSS_BUCKET=oss-ui
MIS_OSS_PUBLIC_BASE_URL=https://yonghemoli.com/images-proxy
